{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://life-engine.dev/schemas/contacts.schema.json",
  "title": "Contact",
  "description": "A contact in the Life Engine canonical data model.",
  "type": "object",
  "required": [
    "id",
    "name",
    "source",
    "source_id",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier assigned by Core"
    },
    "name": {
      "$ref": "#/$defs/ContactName"
    },
    "emails": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ContactEmail"
      },
      "description": "List of email addresses"
    },
    "phones": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ContactPhone"
      },
      "description": "List of phone numbers"
    },
    "addresses": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ContactAddress"
      },
      "description": "List of postal addresses"
    },
    "organization": {
      "type": "string",
      "description": "Company or organization name"
    },
    "title": {
      "type": "string",
      "description": "Job title or role"
    },
    "birthday": {
      "type": "string",
      "format": "date",
      "description": "Date of birth in ISO 8601 date format (YYYY-MM-DD)"
    },
    "photo_url": {
      "type": "string",
      "description": "URL to the contact's photo"
    },
    "notes": {
      "type": "string",
      "description": "Free-text notes about the contact"
    },
    "groups": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Groups or categories the contact belongs to"
    },
    "source": {
      "type": "string",
      "description": "Identifier of the connector or plugin that produced this record"
    },
    "source_id": {
      "type": "string",
      "description": "The record's original ID in the source system"
    },
    "extensions": {
      "type": "object",
      "description": "Plugin-specific fields, namespaced by plugin ID.",
      "patternProperties": {
        "^[a-z][a-z0-9]*(-[a-z0-9]+)*(\\.[a-z][a-z0-9]*(-[a-z0-9]+)*)+$": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Record creation timestamp"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Record last-updated timestamp"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "ContactName": {
      "type": "object",
      "description": "Structured name",
      "required": ["given", "family"],
      "properties": {
        "given": {
          "type": "string",
          "description": "Given/first name"
        },
        "family": {
          "type": "string",
          "description": "Family/last name"
        },
        "prefix": {
          "type": "string",
          "description": "Name prefix (e.g., Mr, Dr)"
        },
        "suffix": {
          "type": "string",
          "description": "Name suffix (e.g., Jr, III)"
        },
        "middle": {
          "type": "string",
          "description": "Middle name"
        }
      },
      "additionalProperties": false
    },
    "ContactEmail": {
      "type": "object",
      "description": "A contact email address",
      "required": ["address"],
      "properties": {
        "address": {
          "type": "string",
          "format": "email",
          "description": "Email address"
        },
        "type": {
          "$ref": "#/$defs/ContactInfoType"
        },
        "primary": {
          "type": "boolean",
          "description": "Whether this is the primary email"
        }
      },
      "additionalProperties": false
    },
    "ContactPhone": {
      "type": "object",
      "description": "A contact phone number",
      "required": ["number"],
      "properties": {
        "number": {
          "type": "string",
          "description": "Phone number (E.164 format recommended)"
        },
        "type": {
          "$ref": "#/$defs/PhoneType"
        },
        "primary": {
          "type": "boolean",
          "description": "Whether this is the primary phone number"
        }
      },
      "additionalProperties": false
    },
    "ContactAddress": {
      "type": "object",
      "description": "A postal address",
      "properties": {
        "street": {
          "type": "string",
          "description": "Street address"
        },
        "city": {
          "type": "string",
          "description": "City"
        },
        "region": {
          "type": "string",
          "description": "State, province, or region"
        },
        "postal_code": {
          "type": "string",
          "description": "Postal or ZIP code"
        },
        "country": {
          "type": "string",
          "description": "Country"
        },
        "type": {
          "$ref": "#/$defs/ContactInfoType"
        }
      },
      "additionalProperties": false
    },
    "ContactInfoType": {
      "type": "string",
      "enum": ["home", "work", "other"],
      "description": "Type label for contact information"
    },
    "PhoneType": {
      "type": "string",
      "enum": ["mobile", "home", "work", "fax", "other"],
      "description": "Type label for phone numbers"
    }
  }
}
