{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://life-engine.dev/schemas/emails.schema.json",
  "title": "Email",
  "description": "An email message in the Life Engine canonical data model.",
  "type": "object",
  "required": [
    "id",
    "subject",
    "from",
    "to",
    "date",
    "source",
    "source_id",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier assigned by Core"
    },
    "subject": {
      "type": "string",
      "description": "Email subject line"
    },
    "from": {
      "$ref": "#/$defs/EmailAddress",
      "description": "Sender"
    },
    "to": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/EmailAddress"
      },
      "description": "Recipient email addresses"
    },
    "cc": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/EmailAddress"
      },
      "description": "CC recipient email addresses"
    },
    "bcc": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/EmailAddress"
      },
      "description": "BCC recipient email addresses"
    },
    "body_text": {
      "type": "string",
      "description": "Plain text body"
    },
    "body_html": {
      "type": "string",
      "description": "HTML body for rich rendering"
    },
    "date": {
      "type": "string",
      "format": "date-time",
      "description": "Date the email was sent or received"
    },
    "message_id": {
      "type": "string",
      "description": "RFC 2822 Message-ID header value"
    },
    "in_reply_to": {
      "type": "string",
      "description": "Message-ID of the email this is replying to, for threading"
    },
    "attachments": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/EmailAttachment"
      },
      "description": "List of attachments"
    },
    "read": {
      "type": "boolean",
      "description": "Whether the email has been read"
    },
    "starred": {
      "type": "boolean",
      "description": "Whether the email is starred or flagged"
    },
    "labels": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Labels or folder assignments"
    },
    "source": {
      "type": "string",
      "description": "Identifier of the connector or plugin that produced this record"
    },
    "source_id": {
      "type": "string",
      "description": "The record's original ID in the source system"
    },
    "extensions": {
      "type": "object",
      "description": "Plugin-specific fields, namespaced by plugin ID.",
      "patternProperties": {
        "^[a-z][a-z0-9]*(-[a-z0-9]+)*(\\.[a-z][a-z0-9]*(-[a-z0-9]+)*)+$": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Record creation timestamp"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Record last-updated timestamp"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "EmailAddress": {
      "type": "object",
      "description": "An email address with optional display name",
      "required": ["address"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Display name"
        },
        "address": {
          "type": "string",
          "format": "email",
          "description": "Email address"
        }
      },
      "additionalProperties": false
    },
    "EmailAttachment": {
      "type": "object",
      "description": "An email attachment",
      "required": ["filename", "mime_type", "size_bytes"],
      "properties": {
        "filename": {
          "type": "string",
          "description": "Original filename"
        },
        "mime_type": {
          "type": "string",
          "description": "MIME type of the attachment"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0,
          "description": "Size in bytes"
        },
        "content_id": {
          "type": "string",
          "description": "Content-ID for inline attachments"
        }
      },
      "additionalProperties": false
    }
  }
}
