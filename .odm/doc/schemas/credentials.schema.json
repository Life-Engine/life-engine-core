{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://life-engine.io/schemas/cdm/credentials.schema.json",
  "title": "Credential",
  "description": "A credential in the Life Engine canonical data model. Credentials intentionally have NO extensions field.",
  "type": "object",
  "required": [
    "id",
    "name",
    "credential_type",
    "service",
    "claims",
    "source",
    "source_id",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    },
    "name": {
      "type": "string"
    },
    "credential_type": {
      "$ref": "#/$defs/CredentialType"
    },
    "service": {
      "type": "string"
    },
    "claims": {},
    "encrypted": {
      "type": "boolean"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string"
    },
    "source_id": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "CredentialType": {
      "type": "string",
      "enum": ["oauth_token", "api_key", "identity_document", "passkey"]
    }
  }
}
