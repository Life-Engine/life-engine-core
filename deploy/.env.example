# Life Engine Core — Environment Configuration
#
# Copy this file to .env and fill in values before starting.
#
# Required:
#   LIFE_ENGINE_STORAGE_PASSPHRASE — Master passphrase for database encryption.
#     Minimum 12 characters recommended. Used with Argon2id key derivation.
#     If empty or unset, encryption may be disabled or produce runtime errors.

LIFE_ENGINE_STORAGE_PASSPHRASE=

# Optional overrides:
# LIFE_ENGINE_CORE_HOST=0.0.0.0
# LIFE_ENGINE_CORE_PORT=3750
# LIFE_ENGINE_CORE_LOG_LEVEL=info
# LIFE_ENGINE_AUTH_PROVIDER=local-token
# LIFE_ENGINE_BEHIND_PROXY=false
