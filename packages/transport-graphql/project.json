{
  "name": "transport-graphql",
  "sourceRoot": "packages/transport-graphql/src",
  "projectType": "library",
  "tags": ["lang:rust", "type:lib", "scope:transport"],
  "namedInputs": {
    "rust": [
      "{projectRoot}/src/**/*.rs",
      "{projectRoot}/Cargo.toml",
      "{workspaceRoot}/Cargo.toml",
      "{workspaceRoot}/Cargo.lock"
    ]
  },
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "inputs": ["rust"],
      "options": {
        "command": "cargo build -p life-engine-transport-graphql",
        "cwd": "{workspaceRoot}"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "inputs": ["rust"],
      "options": {
        "command": "cargo test -p life-engine-transport-graphql",
        "cwd": "{workspaceRoot}"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "inputs": ["rust"],
      "options": {
        "command": "cargo clippy -p life-engine-transport-graphql -- -D warnings",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
