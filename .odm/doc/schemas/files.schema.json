{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://life-engine.dev/schemas/files.schema.json",
  "title": "FileMetadata",
  "description": "File metadata in the Life Engine canonical data model.",
  "type": "object",
  "required": [
    "id",
    "filename",
    "path",
    "mime_type",
    "size_bytes",
    "checksum",
    "source",
    "source_id",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier assigned by Core"
    },
    "filename": {
      "type": "string",
      "description": "Filename including extension"
    },
    "path": {
      "type": "string",
      "description": "Storage path relative to the Core data directory"
    },
    "mime_type": {
      "type": "string",
      "description": "MIME type (e.g. application/pdf, image/png)"
    },
    "size_bytes": {
      "type": "integer",
      "minimum": 0,
      "description": "File size in bytes"
    },
    "checksum": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "SHA-256 hex hash of the file contents"
    },
    "storage_backend": {
      "type": "string",
      "description": "Storage backend identifier"
    },
    "source": {
      "type": "string",
      "description": "Identifier of the connector or plugin that produced this record"
    },
    "source_id": {
      "type": "string",
      "description": "The record's original ID in the source system"
    },
    "extensions": {
      "type": "object",
      "description": "Plugin-specific fields, namespaced by plugin ID.",
      "patternProperties": {
        "^[a-z][a-z0-9]*(-[a-z0-9]+)*(\\.[a-z][a-z0-9]*(-[a-z0-9]+)*)+$": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Record creation timestamp"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Record last-updated timestamp"
    }
  },
  "additionalProperties": false
}
