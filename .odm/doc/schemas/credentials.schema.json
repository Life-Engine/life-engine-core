{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://life-engine.dev/schemas/credentials.schema.json",
  "title": "Credential",
  "description": "A credential in the Life Engine canonical data model.",
  "type": "object",
  "required": [
    "id",
    "name",
    "credential_type",
    "service",
    "claims",
    "source",
    "source_id",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier assigned by Core"
    },
    "name": {
      "type": "string",
      "description": "Human-readable name for the credential"
    },
    "credential_type": {
      "$ref": "#/$defs/CredentialType"
    },
    "service": {
      "type": "string",
      "description": "The service this credential is associated with (e.g., google.com, github.com)"
    },
    "claims": {
      "type": "object",
      "description": "Type-specific data. The shape depends on the credential type."
    },
    "encrypted": {
      "type": "boolean",
      "description": "Whether the credential data is encrypted at rest"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time",
      "description": "Expiration datetime in ISO 8601 format"
    },
    "source": {
      "type": "string",
      "description": "Identifier of the connector or plugin that produced this record"
    },
    "source_id": {
      "type": "string",
      "description": "The record's original ID in the source system"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Record creation timestamp"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Record last-updated timestamp"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "CredentialType": {
      "type": "string",
      "enum": ["oauth_token", "api_key", "identity_document", "passkey"],
      "description": "The type of credential stored"
    }
  }
}
