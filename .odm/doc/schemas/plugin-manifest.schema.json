{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://life-engine.org/schemas/plugin-manifest.schema.json",
  "title": "Life Engine Plugin Manifest",
  "description": "Schema for plugin.json manifest files used by Life Engine App plugins.",
  "type": "object",
  "required": [
    "id",
    "name",
    "version",
    "entry",
    "element",
    "minShellVersion",
    "capabilities"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique plugin identifier in reverse-domain format.",
      "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*(\\.[a-z][a-z0-9]*(-[a-z0-9]+)*)+$",
      "examples": [
        "com.life-engine.todos"
      ]
    },
    "name": {
      "type": "string",
      "description": "Human-readable display name.",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "description": "Semver version string.",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9.]+)?(\\+[a-zA-Z0-9.]+)?$"
    },
    "entry": {
      "type": "string",
      "description": "Path to the plugin's JavaScript entry file, relative to package root.",
      "minLength": 1
    },
    "element": {
      "type": "string",
      "description": "Custom element tag name the plugin registers. Must contain a hyphen per the Web Components spec.",
      "pattern": "^[a-z][a-z0-9]*-[a-z0-9-]*$"
    },
    "minShellVersion": {
      "type": "string",
      "description": "Minimum compatible App shell version (semver).",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9.]+)?(\\+[a-zA-Z0-9.]+)?$"
    },
    "sidebar": {
      "type": "object",
      "deprecated": true,
      "description": "Deprecated: use slots with type 'sidebar.item' instead. Sidebar configuration for the plugin.",
      "required": [
        "label",
        "icon"
      ],
      "properties": {
        "label": {
          "type": "string",
          "description": "Label shown in the sidebar.",
          "minLength": 1
        },
        "icon": {
          "type": "string",
          "description": "Icon identifier for the sidebar entry.",
          "minLength": 1
        },
        "order": {
          "type": "integer",
          "description": "Sort order in the sidebar."
        }
      },
      "additionalProperties": false
    },
    "slots": {
      "type": "array",
      "description": "UI mounting points the plugin registers for. Each slot declares a type and type-specific configuration.",
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["sidebar.item", "main.page", "command.palette", "dashboard.widget", "settings.page", "context.menu"],
            "description": "The slot type this entry registers for."
          },
          "label": { "type": "string", "minLength": 1 },
          "icon": { "type": "string", "minLength": 1 },
          "order": { "type": "integer" },
          "commands": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "label", "action"],
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "label": { "type": "string", "minLength": 1 },
                "action": { "type": "string", "minLength": 1 }
              },
              "additionalProperties": false
            }
          },
          "element": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9]*-[a-z0-9-]*$"
          },
          "defaultSize": {
            "type": "string",
            "enum": ["small", "medium", "large"]
          },
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "label", "action"],
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "label": { "type": "string", "minLength": 1 },
                "action": { "type": "string", "minLength": 1 },
                "scope": {
                  "type": "string",
                  "enum": ["global", "collection"]
                }
              },
              "additionalProperties": false
            }
          }
        },
        "allOf": [
          {
            "if": { "properties": { "type": { "const": "sidebar.item" } } },
            "then": { "required": ["label", "icon"] }
          },
          {
            "if": { "properties": { "type": { "const": "command.palette" } } },
            "then": { "required": ["commands"] }
          },
          {
            "if": { "properties": { "type": { "const": "dashboard.widget" } } },
            "then": { "required": ["element", "defaultSize"] }
          },
          {
            "if": { "properties": { "type": { "const": "context.menu" } } },
            "then": { "required": ["items"] }
          }
        ]
      }
    },
    "capabilities": {
      "type": "array",
      "description": "Capability strings the plugin requires (e.g. data:read:tasks, network:fetch).",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "description": {
      "type": "string",
      "description": "Short description for the plugin directory."
    },
    "author": {
      "description": "Author name or object with name/email/url.",
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "required": [
            "name"
          ],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "email": {
              "type": "string",
              "format": "email"
            },
            "url": {
              "type": "string",
              "format": "uri"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "license": {
      "type": "string",
      "description": "SPDX licence identifier."
    },
    "commandPalette": {
      "type": "array",
      "deprecated": true,
      "description": "Deprecated: use slots with type 'command.palette' instead. Command palette entries for the plugin.",
      "items": {
        "type": "object",
        "required": [
          "id",
          "label",
          "action"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique command identifier within the plugin.",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "description": "Human-readable label shown in the command palette.",
            "minLength": 1
          },
          "action": {
            "type": "string",
            "description": "Action identifier triggered when the command is selected.",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "dashboard": {
      "type": "object",
      "deprecated": true,
      "description": "Deprecated: use slots with type 'dashboard.widget' instead. Dashboard widget configuration.",
      "required": [
        "element",
        "defaultSize"
      ],
      "properties": {
        "element": {
          "type": "string",
          "description": "Custom element tag name for the dashboard widget.",
          "pattern": "^[a-z][a-z0-9]*-[a-z0-9-]*$"
        },
        "defaultSize": {
          "type": "string",
          "description": "Default widget size on the dashboard.",
          "enum": [
            "small",
            "medium",
            "large"
          ]
        }
      },
      "additionalProperties": false
    },
    "collections": {
      "type": "array",
      "description": "Private collection definitions for the plugin.",
      "items": {
        "type": "object",
        "required": [
          "name",
          "schema"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Collection name.",
            "minLength": 1
          },
          "schema": {
            "type": "string",
            "description": "Path to the JSON Schema file for this collection.",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "allowedDomains": {
      "type": "array",
      "description": "Domain strings the plugin may make HTTP requests to.",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "settings": {
      "type": "array",
      "description": "Settings schema for auto-rendered plugin settings UI.",
      "items": {
        "$ref": "#/$defs/PluginSetting"
      }
    },
    "dependencies": {
      "type": "object",
      "description": "Plugin dependencies.",
      "properties": {
        "sharedModules": {
          "type": "array",
          "description": "Shared module names the plugin consumes. Supported: lit, react, react-dom.",
          "items": {
            "type": "string",
            "enum": [
              "lit",
              "react",
              "react-dom"
            ]
          }
        }
      },
      "additionalProperties": false
    },
    "largeBundle": {
      "type": "boolean",
      "description": "Required when the gzipped plugin bundle exceeds 200 KB. Plugins over 2 MB are rejected."
    },
    "migrations": {
      "type": "array",
      "description": "Schema migration entries for upgrading existing records when the plugin version changes.",
      "items": {
        "type": "object",
        "required": ["from", "to", "transform"],
        "properties": {
          "from": {
            "type": "string",
            "description": "Semver range matching the source schema version (e.g., 1.x, 1.0.x)."
          },
          "to": {
            "type": "string",
            "description": "Exact semver version records will have after migration."
          },
          "transform": {
            "type": "string",
            "description": "Relative path from plugin root to the migration script.",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "description": "Human-readable summary of what the migration does."
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "PluginSetting": {
      "type": "object",
      "required": [
        "key",
        "label",
        "type"
      ],
      "properties": {
        "key": {
          "type": "string",
          "description": "Unique setting identifier within the plugin's namespace.",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "description": "Human-readable label shown in the settings UI.",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "description": "Setting value type.",
          "enum": [
            "select",
            "boolean",
            "string",
            "number"
          ]
        },
        "options": {
          "type": "array",
          "description": "Allowed values (required when type is select).",
          "items": {
            "type": "string"
          }
        },
        "default": {
          "description": "Default value applied when the user has not set a preference."
        }
      },
      "additionalProperties": false,
      "if": {
        "properties": {
          "type": {
            "const": "select"
          }
        }
      },
      "then": {
        "required": [
          "options"
        ]
      }
    }
  }
}
