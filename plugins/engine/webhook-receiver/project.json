{
  "name": "webhook-receiver",
  "sourceRoot": "plugins/engine/webhook-receiver/src",
  "projectType": "library",
  "tags": ["lang:rust", "type:plugin"],
  "namedInputs": {
    "rust": [
      "{projectRoot}/src/**/*.rs",
      "{projectRoot}/Cargo.toml",
      "{workspaceRoot}/Cargo.toml",
      "{workspaceRoot}/Cargo.lock"
    ]
  },
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "inputs": ["rust"],
      "options": {
        "command": "cargo build -p webhook-receiver --target wasm32-wasip1",
        "cwd": "{workspaceRoot}"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "inputs": ["rust"],
      "options": {
        "command": "cargo test -p webhook-receiver",
        "cwd": "{workspaceRoot}"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "inputs": ["rust"],
      "options": {
        "command": "cargo clippy -p webhook-receiver -- -D warnings",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
