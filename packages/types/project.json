{
  "name": "types",
  "sourceRoot": "packages/types/src",
  "projectType": "library",
  "tags": ["lang:rust", "lang:typescript", "type:lib"],
  "namedInputs": {
    "rust": [
      "{projectRoot}/src/**/*.rs",
      "{projectRoot}/Cargo.toml",
      "{workspaceRoot}/Cargo.toml",
      "{workspaceRoot}/Cargo.lock"
    ],
    "typescript": [
      "{projectRoot}/ts/**/*.ts",
      "{projectRoot}/tsconfig.json",
      "{projectRoot}/vitest.config.ts",
      "{projectRoot}/package.json"
    ]
  },
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "inputs": ["rust"],
      "options": {
        "command": "cargo build -p life-engine-types",
        "cwd": "{workspaceRoot}"
      }
    },
    "build-ts": {
      "executor": "nx:run-commands",
      "inputs": ["typescript"],
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "pnpm --filter @life-engine/types run build",
        "cwd": "{workspaceRoot}"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "inputs": ["rust"],
      "options": {
        "command": "cargo test -p life-engine-types",
        "cwd": "{workspaceRoot}"
      }
    },
    "test-ts": {
      "executor": "nx:run-commands",
      "inputs": ["typescript"],
      "options": {
        "command": "pnpm --filter @life-engine/types run test",
        "cwd": "{workspaceRoot}"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "inputs": ["rust"],
      "options": {
        "command": "cargo clippy -p life-engine-types -- -D warnings",
        "cwd": "{workspaceRoot}"
      }
    },
    "type-check": {
      "executor": "nx:run-commands",
      "inputs": ["typescript"],
      "options": {
        "command": "pnpm --filter @life-engine/types run type-check",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
