{
  "name": "life-engine-core",
  "version": "0.1.0",
  "private": true,
  "description": "Life Engine Core — personal data engine with polyglot monorepo",
  "license": "Apache-2.0",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "npx nx run core:dev",
    "build": "npx nx run-many -t build",
    "build:ts": "npx nx run-many -t build-ts",
    "test": "npx nx run-many -t test",
    "test:ts": "npx nx run-many -t test-ts",
    "lint": "npx nx run-many -t lint",
    "type-check": "npx nx run-many -t type-check",
    "affected:test": "npx nx affected -t test",
    "affected:build": "npx nx affected -t build"
  },
  "devDependencies": {
    "nx": "^20.4.0",
    "@nx/js": "^20.4.0",
    "@nx/vite": "^20.4.0",
    "@nx/react": "^20.4.0"
  }
}
