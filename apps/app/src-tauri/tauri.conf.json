{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/main/.schema/tauri.conf.schema.json",
  "productName": "Life Engine",
  "version": "0.1.0",
  "identifier": "com.life-engine.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "title": "Life Engine",
    "windows": [
      {
        "title": "Life Engine",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:*"
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/life-engine-core"
    ],
    "resources": [
      "resources/plugins/**/*",
      "resources/workflows/**/*"
    ],
    "targets": "all"
  },
  "plugins": {}
}
