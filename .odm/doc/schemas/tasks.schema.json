{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://life-engine.dev/schemas/tasks.schema.json",
  "title": "Task",
  "description": "A task in the Life Engine canonical data model.",
  "type": "object",
  "required": [
    "id",
    "title",
    "source",
    "source_id",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier assigned by Core"
    },
    "title": {
      "type": "string",
      "description": "Task title"
    },
    "description": {
      "type": "string",
      "description": "Detailed description of the task"
    },
    "status": {
      "$ref": "#/$defs/TaskStatus"
    },
    "priority": {
      "$ref": "#/$defs/TaskPriority"
    },
    "due_date": {
      "type": "string",
      "format": "date-time",
      "description": "Due date in ISO 8601 format"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the task was completed"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "User-defined tags for categorisation"
    },
    "assignee": {
      "type": "string",
      "description": "Assigned user or entity"
    },
    "parent_id": {
      "type": "string",
      "format": "uuid",
      "description": "Parent task ID for subtask relationships"
    },
    "source": {
      "type": "string",
      "description": "Identifier of the connector or plugin that produced this record"
    },
    "source_id": {
      "type": "string",
      "description": "The record's original ID in the source system"
    },
    "extensions": {
      "type": "object",
      "description": "Plugin-specific fields, namespaced by plugin ID.",
      "patternProperties": {
        "^[a-z][a-z0-9]*(-[a-z0-9]+)*(\\.[a-z][a-z0-9]*(-[a-z0-9]+)*)+$": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Record creation timestamp"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Record last-updated timestamp"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "TaskStatus": {
      "type": "string",
      "enum": ["pending", "in_progress", "completed", "cancelled"],
      "description": "Current status of the task"
    },
    "TaskPriority": {
      "type": "string",
      "enum": ["low", "medium", "high", "urgent"],
      "description": "Priority level of the task"
    }
  }
}
