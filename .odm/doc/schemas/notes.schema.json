{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://life-engine.dev/schemas/notes.schema.json",
  "title": "Note",
  "description": "A note in the Life Engine canonical data model.",
  "type": "object",
  "required": [
    "id",
    "title",
    "body",
    "source",
    "source_id",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier assigned by Core"
    },
    "title": {
      "type": "string",
      "description": "Note title"
    },
    "body": {
      "type": "string",
      "description": "Note content"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Tags for categorisation and search"
    },
    "format": {
      "$ref": "#/$defs/NoteFormat"
    },
    "pinned": {
      "type": "boolean",
      "description": "Whether this note is pinned"
    },
    "source": {
      "type": "string",
      "description": "Identifier of the connector or plugin that produced this record"
    },
    "source_id": {
      "type": "string",
      "description": "The record's original ID in the source system"
    },
    "extensions": {
      "type": "object",
      "description": "Plugin-specific fields, namespaced by plugin ID.",
      "patternProperties": {
        "^[a-z][a-z0-9]*(-[a-z0-9]+)*(\\.[a-z][a-z0-9]*(-[a-z0-9]+)*)+$": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Record creation timestamp"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Record last-updated timestamp"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "NoteFormat": {
      "type": "string",
      "enum": ["plain", "markdown", "html"],
      "description": "Content format of the note"
    }
  }
}
