{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "sharedGlobals": ["{workspaceRoot}/.github/**/*"],
    "rust": [
      "{projectRoot}/src/**/*.rs",
      "{projectRoot}/Cargo.toml",
      "{projectRoot}/tests/**/*.rs",
      "{workspaceRoot}/Cargo.toml",
      "{workspaceRoot}/Cargo.lock"
    ],
    "typescript": [
      "{projectRoot}/src/**/*.ts",
      "{projectRoot}/src/**/*.tsx",
      "{projectRoot}/tsconfig.json",
      "{projectRoot}/package.json"
    ]
  },
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "build-ts": {
      "dependsOn": ["^build-ts"],
      "cache": true
    },
    "test": {
      "dependsOn": ["build"],
      "cache": true
    },
    "test-ts": {
      "dependsOn": ["build-ts"],
      "cache": true
    },
    "lint": {
      "cache": true
    },
    "type-check": {
      "dependsOn": ["build-ts"],
      "cache": true
    },
    "dev": {
      "cache": false
    }
  },
  "defaultBase": "main"
}
