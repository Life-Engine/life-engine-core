{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://life-engine.io/schemas/cdm/files.schema.json",
  "title": "FileMetadata",
  "description": "File metadata in the Life Engine canonical data model.",
  "type": "object",
  "required": [
    "id",
    "filename",
    "path",
    "mime_type",
    "size_bytes",
    "checksum",
    "source",
    "source_id",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    },
    "filename": {
      "type": "string"
    },
    "path": {
      "type": "string"
    },
    "mime_type": {
      "type": "string"
    },
    "size_bytes": {
      "type": "integer",
      "minimum": 0
    },
    "checksum": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "storage_backend": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "source_id": {
      "type": "string"
    },
    "extensions": {},
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": true
}
