# Life Engine Core — Docker environment variables
#
# Copy this file to .env and fill in the values.
# These variables override config.toml settings when running in Docker.

# Storage passphrase for SQLCipher database encryption (required)
LIFE_ENGINE_STORAGE_PASSPHRASE=

# Server bind address and port
# LIFE_ENGINE_CORE_HOST=0.0.0.0
# LIFE_ENGINE_CORE_PORT=3750

# Log level: trace, debug, info, warn, error
# LIFE_ENGINE_CORE_LOG_LEVEL=info

# Data directory inside the container (mapped via volume)
# LIFE_ENGINE_CORE_DATA_DIR=/data

# Storage database path
# LIFE_ENGINE_STORAGE_PATH=/data/core.db

# REST transport port
# LIFE_ENGINE_TRANSPORTS_REST_PORT=3750

# Authentication provider: local-token, oidc
# LIFE_ENGINE_AUTH_PROVIDER=local-token

# OIDC settings (required when AUTH_PROVIDER=oidc)
# LIFE_ENGINE_OIDC_ISSUER_URL=
# LIFE_ENGINE_OIDC_CLIENT_ID=

# Set to true when running behind a reverse proxy that terminates TLS
# LIFE_ENGINE_BEHIND_PROXY=false
